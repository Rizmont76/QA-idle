{
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "health": "node scripts/repository-health.mjs",
    "balance:baseline": "node scripts/balance/run-balance-simulation.mjs",
    "balance:search": "node scripts/balance/search-balance-parameters.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run health && npm run test:run",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "^5.9.3",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
